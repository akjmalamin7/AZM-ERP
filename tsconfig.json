{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "rootDir": "./src",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src/**/*"]
}
